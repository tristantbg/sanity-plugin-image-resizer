{
    "name": "sanity-plugin-image-resizer",
    "version": "1.0.4",
    "description": "Sanity Studio tool to batch-optimise image assets — resize, compress and convert formats",
    "keywords": [
        "sanity",
        "sanity-plugin"
    ],
    "homepage": "https://github.com/tristantbg/sanity-plugin-image-resizer#readme",
    "bugs": {
        "url": "https://github.com/tristantbg/sanity-plugin-image-resizer/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/tristantbg/sanity-plugin-image-resizer.git"
    },
    "license": "MIT",
    "author": "Tristan Bagot <hello@tristanbagot.com>",
    "sideEffects": false,
    "type": "commonjs",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "sanity.json",
        "src",
        "v2-incompatible.js"
    ],
    "scripts": {
        "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
        "dev": "pnpm link-watch",
        "format": "prettier --write --cache --ignore-unknown .",
        "link-watch": "plugin-kit link-watch",
        "lint": "eslint .",
        "prepublishOnly": "npm run build",
        "watch": "pkg-utils watch --strict"
    },
    "browserslist": "extends @sanity/browserslist-config",
    "dependencies": {
        "@sanity/icons": "^3.7.4",
        "@sanity/incompatible-plugin": "^1.0.5",
        "@sanity/ui": "^3.1.14"
    },
    "devDependencies": {
        "@sanity/pkg-utils": "^10.4.11",
        "@sanity/plugin-kit": "^4.0.20",
        "@types/react": "^19.2.14",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-config-sanity": "^7.1.4",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "prettier": "^3.8.1",
        "prettier-plugin-packagejson": "^3.0.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sanity": "^5.17.1",
        "styled-components": "6.3.12",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "react": "^18 || ^19",
        "sanity": "^3 || ^5"
    },
    "engines": {
        "node": ">=18"
    },
    "sanityPlugin": {
        "verifyPackage": {
            "eslintImports": false
        }
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
